{
  "name": "atharv-ai",
  "version": "1.0.1",
  "author": "Atharv Remeshan",
  "description": "Local AI Desktop App",
  "main": "main.js",

  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },

  "dependencies": {
    "wait-on": "^8.0.0"
  },

  "devDependencies": {
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1"
  },

  "build": {
    "appId": "com.atharv.ai",

    "productName": "Atharv AI",

    "directories": {
      "output": "dist"
    },

    "files": [
      "**/*",
      "!node_modules/.cache/**/*"
    ],

    "asar": true,

    "win": {
      "target": "msi",
      "icon": "assets/icon.ico"
    }
  }
}